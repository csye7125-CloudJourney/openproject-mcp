# openproject-mcp server config
# copy this to .env and fill in your values

# Required. OpenProject URL.
OPENPROJECT_BASE_URL=https://your-openproject-instance.com

# Required. OpenProject API key.
# Generate one under My Account -> Access tokens.
OPENPROJECT_API_KEY=your-api-key-here

# Optional. Request timeout in seconds (default 30).
OPENPROJECT_TIMEOUT=30

# Optional. Verify SSL certs (default true).
OPENPROJECT_VERIFY_SSL=true

# Optional. Log level (default INFO).
# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# Optional. Log format (default json).
# json or text
LOG_FORMAT=json