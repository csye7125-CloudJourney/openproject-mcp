# env file for the docker-compose stacks. copy to .env and fill in.

OPENPROJECT_BASE_URL=http://openproject:8080
OPENPROJECT_API_KEY=your-api-key-here
OPENPROJECT_TIMEOUT=30
OPENPROJECT_VERIFY_SSL=true

LOG_LEVEL=INFO
LOG_FORMAT=json

# only needed when using docker-compose.openproject.yml (full stack)
OPENPROJECT_SECRET_KEY_BASE=your-secret-key-base-here
OPENPROJECT_HOST_NAME=localhost:8080
